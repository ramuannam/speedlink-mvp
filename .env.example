# Local development environment variables for SpeedLink.
# Use these values with SPRING_PROFILES_ACTIVE=local when running backend on your machine.

# PostgreSQL connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=speedlink
DB_USERNAME=speedlink
DB_PASSWORD=password

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend security
SPEEDLINK_JWT_SECRET=replace-with-a-long-local-dev-secret
SPEEDLINK_TOKEN_TTL_MINUTES=720
SPEEDLINK_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Auth dev project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Spring Boot profile
SPRING_PROFILES_ACTIVE=local
